# ─────────────────────────────────────────────────────────────────────────────
# AgroControl Campo — variables de entorno
# Copia este archivo a `.env.local` y completa los valores. NO subir secretos.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (Fase 4). Proyecto propio de la app (ver ADR-0001).
#   URL del proyecto, p. ej. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
#   anon key (pública; el acceso lo controla RLS). NO usar la service_role aquí.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (Fase 5, observabilidad). Opcional hasta entonces.
# NEXT_PUBLIC_SENTRY_DSN=
